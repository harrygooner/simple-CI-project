pipeline {
    agent {
        label 'docker-agent'
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        APP_DIR = 'app'
        HELM_CHART_DIR = 'app/helm'

        IMAGE_NAME = 'thitbobam/python-app'
        IMAGE_TAG = "v${BUILD_NUMBER}"

        K8S_NAMESPACE = 'devops-demo'
        HELM_RELEASE = 'python-app'
        LOCAL_CHECK_PORT = '8081'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare') {
            steps {
                sh '''
                    echo "Checking tools..."
                    python3 --version
                    docker --version
                    kubectl version --client
                    helm version
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    cd ${APP_DIR}
                    python3 -m venv .venv
                    . .venv/bin/activate
                    python -m pip install --upgrade pip
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Unit Test') {
            steps {
                sh '''
                    cd ${APP_DIR}
                    . .venv/bin/activate
                    mkdir -p test-results
                    python -m pytest test/test_app.py -v --junitxml=test-results/unit.xml
                '''
            }
            post {
                always {
                    junit 'app/test-results/unit.xml'
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    docker build \
                      -t ${IMAGE_NAME}:${IMAGE_TAG} \
                      -t ${IMAGE_NAME}:latest \
                      ${APP_DIR}
                '''
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKERHUB_USER',
                        passwordVariable: 'DOCKERHUB_TOKEN'
                    )
                ]) {
                    sh '''
                        echo "${DOCKERHUB_TOKEN}" | docker login -u "${DOCKERHUB_USER}" --password-stdin
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${IMAGE_NAME}:latest
                        docker logout
                    '''
                }
            }
        }

        stage('Helm Lint') {
            steps {
                sh '''
                    helm lint ${HELM_CHART_DIR}
                '''
            }
        }

        stage('Deploy to Kubernetes with Helm') {
            steps {
                withCredentials([
                    file(credentialsId: 'kubeconfig-kind', variable: 'KUBECONFIG_FILE')
                ]) {
                    sh '''
                        set -e

                        export KUBECONFIG="${KUBECONFIG_FILE}"

                        echo "Checking Kubernetes connection..."
                        kubectl get nodes

                        echo "Ensuring namespace exists..."
                        kubectl create namespace ${K8S_NAMESPACE} \
                          --dry-run=client \
                          -o yaml | kubectl apply -f -

                        echo "Getting current Helm revision for rollback..."
                        PREV_REVISION=$(helm history ${HELM_RELEASE} \
                          -n ${K8S_NAMESPACE} 2>/dev/null | awk 'END {if (NR>1) print $1}' || true)

                        echo "Previous revision: ${PREV_REVISION}"

                        echo "Deploying with Helm..."
                        set +e
                        helm upgrade --install ${HELM_RELEASE} ${HELM_CHART_DIR} \
                          --namespace ${K8S_NAMESPACE} \
                          --set image.repository=${IMAGE_NAME} \
                          --set image.tag=${IMAGE_TAG} \
                          --set env.APP_ENV=production \
                          --wait \
                          --atomic \
                          --timeout 3m
                        HELM_STATUS=$?
                        set -e

                        if [ ${HELM_STATUS} -ne 0 ]; then
                            echo "Helm deployment failed."

                            if [ -n "${PREV_REVISION}" ]; then
                                echo "Rolling back to revision ${PREV_REVISION}..."
                                helm rollback ${HELM_RELEASE} ${PREV_REVISION} -n ${K8S_NAMESPACE} --wait --timeout 3m
                            else
                                echo "No previous revision found. Rollback skipped."
                            fi

                            exit ${HELM_STATUS}
                        fi

                        echo "Checking rollout status..."
                        kubectl -n ${K8S_NAMESPACE} rollout status deployment/${HELM_RELEASE} --timeout=120s

                        echo "Starting port-forward for health check..."
                        kubectl -n ${K8S_NAMESPACE} port-forward svc/${HELM_RELEASE} ${LOCAL_CHECK_PORT}:5000 > /tmp/port-forward.log 2>&1 &
                        PF_PID=$!

                        cleanup() {
                            kill ${PF_PID} 2>/dev/null || true
                        }
                        trap cleanup EXIT

                        sleep 5

                        echo "Running health check..."
                        if ! curl -fsS http://127.0.0.1:${LOCAL_CHECK_PORT}/; then
                            echo "Health check failed."
                            cat /tmp/port-forward.log || true

                            echo "Application logs:"
                            kubectl -n ${K8S_NAMESPACE} logs deployment/${HELM_RELEASE} --tail=100 || true

                            if [ -n "${PREV_REVISION}" ]; then
                                echo "Rolling back to revision ${PREV_REVISION}..."
                                helm rollback ${HELM_RELEASE} ${PREV_REVISION} -n ${K8S_NAMESPACE} --wait --timeout 3m
                            else
                                echo "No previous revision found. Rollback skipped."
                            fi

                            exit 1
                        fi

                        echo "Helm deployment and health check completed successfully."
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully."
            echo "Image pushed: ${IMAGE_NAME}:${IMAGE_TAG}"
            echo "Helm release: ${HELM_RELEASE}"
            echo "Namespace: ${K8S_NAMESPACE}"
        }

        failure {
            echo "Pipeline failed. Check failed stage logs."
        }

        always {
            withCredentials([
                file(credentialsId: 'kubeconfig-kind', variable: 'KUBECONFIG_FILE')
            ]) {
                sh '''
                    export KUBECONFIG="${KUBECONFIG_FILE}"
                    echo "Current Kubernetes resources:"
                    kubectl -n ${K8S_NAMESPACE} get all || true

                    echo "Helm history:"
                    helm history ${HELM_RELEASE} -n ${K8S_NAMESPACE} || true
                '''
            }
        }

        cleanup {
            sh '''
                docker image prune -f || true
            '''
        }
    }
}