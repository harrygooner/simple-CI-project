pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "thitbobam/python-app"
        IMAGE_TAG = "v${env.BUILD_NUMBER}"
        HELM_RELEASE_NAME = "python-app-release"
        HELM_DIR = "./app/helm"
        K8S_NAMESPACE = "default"
        APP_NAME = "python-app-release-python-app"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "1. Lấy mã nguồn mới nhất từ Repository..."
                checkout scm
            }
        }

        stage('Unit Test') {
            steps {
                echo "2. Chạy Unit Test cho ứng dụng Python..."
                sh '''
                    set -e
                    python3 -m pip install --upgrade pip
                    python3 -m pip install -r app/requirements.txt
                    python3 -m pytest app/test/test_app.py
                '''
            }
        }

        stage('Build & Push Docker Image') {
            steps {
                script {
                    echo "3. Build và Push Image: ${DOCKER_IMAGE}:${IMAGE_TAG}"
                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh '''
                            set -e
                            echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                            docker build -t "$DOCKER_IMAGE:$IMAGE_TAG" ./app
                            docker push "$DOCKER_IMAGE:$IMAGE_TAG"
                        '''
                    }
                }
            }
        }

        stage('Deploy to K8s with Helm') {
            steps {
                echo "4. Triển khai ứng dụng lên Kubernetes bằng Helm..."
                sh '''
                    set -e
                    helm upgrade --install "$HELM_RELEASE_NAME" "$HELM_DIR" \
                        --set image.repository="$DOCKER_IMAGE" \
                        --set image.tag="$IMAGE_TAG" \
                        --namespace "$K8S_NAMESPACE"
                '''
            }
        }

        stage('Integration Test & Health Check') {
            steps {
                script {
                    echo "5. Kiểm tra sức khỏe server sau khi deploy..."
                    sh '''
                        set -e
                        kubectl rollout status deployment/$APP_NAME \
                            --namespace "$K8S_NAMESPACE" \
                            --timeout=90s

                        kubectl port-forward service/$APP_NAME 8080:80 \
                            --namespace "$K8S_NAMESPACE" > /tmp/port-forward.log 2>&1 &
                        PORT_FORWARD_PID=$!

                        cleanup() {
                            kill $PORT_FORWARD_PID 2>/dev/null || true
                        }
                        trap cleanup EXIT

                        sleep 5
                        APP_URL="http://localhost:8080/" python3 -m pytest app/test/integration_test.py
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ TẤT CẢ THÀNH CÔNG! Ứng dụng phiên bản ${IMAGE_TAG} đã được live."
        }
        failure {
            echo "❌ PIPELINE THẤT BẠI! Đang rollback về phiên bản an toàn trước đó..."
            sh '''
                helm rollback "$HELM_RELEASE_NAME" --namespace "$K8S_NAMESPACE" \
                    || echo "Rollback không thành công hoặc đây là lần deploy đầu tiên."
            '''
        }
        always {
            sh 'docker logout || true'
        }
    }
}
