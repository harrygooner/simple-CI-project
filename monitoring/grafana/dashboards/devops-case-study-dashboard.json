      "title": "Python App Up",
      "description": "Current scrape status for the Flask application metrics endpoint.",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "max_over_time(up{job=\"$app_job\"}[2m])",
          "legendFormat": "",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
