    {
      "id": 20,
      "type": "stat",
      "title": "Jenkins Queue Size",
      "description": "Number of builds waiting in Jenkins queue. High values can indicate unavailable agents or build bottlenecks.",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "max({job=\"$jenkins_job\", __name__=~\"jenkins_queue_size_value|default_jenkins_queue_size_value\"})",
          "legendFormat": "",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
