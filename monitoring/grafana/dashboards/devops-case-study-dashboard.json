{
  "id": null,
  "uid": "devops-case-study-resource-monitoring",
  "title": "DevOps Case Study - App, Jenkins & K8s Pod Observability",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Python App Up",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "up{job=\"python-app\"}",
          "legendFormat": "app"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN"
                },
                "1": {
                  "text": "UP"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Jenkins Up",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "up{job=\"jenkins\"}",
          "legendFormat": "jenkins"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN"
                },
                "1": {
                  "text": "UP"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "Application Request Rate",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(rate(flask_http_requests_total[1m]))",
          "legendFormat": "requests/sec"
        }
      ],
      "id": 3
    },
    {
      "type": "timeseries",
      "title": "Application Status Code Rate",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (http_status) (rate(flask_http_requests_total[1m]))",
          "legendFormat": "{{http_status}}"
        }
      ],
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Application P95 Latency",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ],
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Application P50 Latency",
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50 latency"
        }
      ],
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests by Endpoint",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(flask_http_requests_total[1m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "5xx Error Rate",
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(rate(flask_http_requests_total{http_status=~\"5..\"}[1m]))",
          "legendFormat": "5xx/sec"
        }
      ],
      "id": 8
    },
    {
      "type": "text",
      "title": "Resource Metrics Notes",
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "Resource panels below focus only on **Kubernetes application Pod metrics**: Pod CPU, Pod memory, restart count and Deployment available replicas. These panels do **not** use a standalone cAdvisor container in Docker Compose. They require Kubernetes-native metrics such as kubelet/cAdvisor metrics and kube-state-metrics, for example through `kube-prometheus-stack`. If kube-prometheus-stack is not installed or connected as a data source, these panels may show no data."
      },
      "id": 9
    },
    {
      "type": "timeseries",
      "title": "App Pod CPU Usage",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"devops-demo\", pod=~\"python-app.*\", container!=\"POD\", image!=\"\"}[5m]))",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores"
        },
        "overrides": []
      },
      "description": "CPU usage of python-app Pods in Kubernetes. Requires kubelet/cAdvisor metrics or kube-prometheus-stack.",
      "id": 10
    },
    {
      "type": "timeseries",
      "title": "App Pod Memory Usage",
      "gridPos": {
        "x": 12,
        "y": 30,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"devops-demo\", pod=~\"python-app.*\", container!=\"POD\", image!=\"\"})",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "description": "Memory working set of python-app Pods. Requires kubelet/cAdvisor metrics or kube-prometheus-stack.",
      "id": 11
    },
    {
      "type": "timeseries",
      "title": "App Pod Restart Count",
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (pod) (kube_pod_container_status_restarts_total{namespace=\"devops-demo\", pod=~\"python-app.*\"})",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "description": "Restart count of python-app Pods. Requires kube-state-metrics.",
      "id": 12
    },
    {
      "type": "timeseries",
      "title": "Deployment Available Replicas",
      "gridPos": {
        "x": 12,
        "y": 38,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"devops-demo\", deployment=\"python-app\"}",
          "legendFormat": "available replicas"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "description": "Available replicas for python-app Deployment. Requires kube-state-metrics.",
      "id": 13
    }
  ]
}